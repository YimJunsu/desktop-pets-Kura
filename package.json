{
  "name": "kuro-pet",
  "version": "1.0.0",
  "description": "Claude Code Octopus Desktop Pet",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "keywords": [
    "electron",
    "desktop-pet",
    "claude-code"
  ],
  "author": "Kura",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.4",
    "sqlite3": "^6.0.1",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kuro.desktop-pet",
    "productName": "Kuro Desktop Pet",
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "assets/**/*",
      "config/**/*",
      "package.json",
      "!assets/**/*.ps1"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/app-icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kuro Desktop Pet"
    },
    "publish": {
      "provider": "github",
      "owner": "YimJunsu",
      "repo": "desktop-pets-Kura"
    }
  }
}
